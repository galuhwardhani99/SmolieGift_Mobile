<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDialogJudul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#2D3142"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnTutupDialog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="✕"
                    android:textColor="#64748B"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilihan Warna / Motif"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spWarna"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_spinner"
                        android:layout_marginBottom="16dp"
                        android:spinnerMode="dropdown"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Pilihan Kemasan"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgKemasan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <RadioButton
                            android:id="@+id/rbPlastik"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:buttonTint="#DD3827"
                            android:text="Plastik &amp; Kawat Emas" />

                        <RadioButton
                            android:id="@+id/rbTile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:buttonTint="#DD3827"
                            android:text="Bungkus Tile (+Rp 1.000)" />

                        <RadioButton
                            android:id="@+id/rbBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:buttonTint="#DD3827"
                            android:text="Box Eksklusif (+Rp 2.500)" />
                    </RadioGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Ekstra Tambahan"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbSablon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:buttonTint="#DD3827"
                        android:text="Sablon Nama / Inisial (+Rp 500)" />

                    <CheckBox
                        android:id="@+id/cbThanksCard"
                        android:layout_width="match_parent"
                        app:buttonTint="#DD3827"
                        android:layout_height="wrap_content"
                        android:text="Thanks Card (+Rp 300)" />

                    <CheckBox
                        android:id="@+id/cbInvitedCard"
                        android:layout_width="match_parent"
                        app:buttonTint="#DD3827"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Invited Card (Cetak Tanggal) (+Rp 400)" />

                    <LinearLayout
                        android:id="@+id/llContainerTanggalAcara"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:background="#FFF5F5"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tentukan Waktu Acara"
                            android:textColor="#DD3827"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnPilihTanggal"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="40dp"
                                android:text="Pilih Tanggal"
                                android:textSize="10sp"
                                android:textColor="#64748B"
                                android:backgroundTint="#FFFFFF"
                                app:strokeColor="#DDDDDD"
                                app:strokeWidth="1dp"
                                android:layout_marginEnd="4dp"
                                app:cornerRadius="6dp"/>

                            <Button
                                android:id="@+id/btnPilihWaktu"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="40dp"
                                android:text="Pilih Waktu"
                                android:textSize="10sp"
                                android:textColor="#64748B"
                                android:backgroundTint="#FFFFFF"
                                app:strokeColor="#DDDDDD"
                                app:strokeWidth="1dp"
                                android:layout_marginStart="4dp"
                                app:cornerRadius="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="#F5F6F8"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Custom Desain &amp; Catatan"
                            android:textColor="#2D3142"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:textColor="#64748B"
                            android:text="Tulis instruksi khusus atau permintaan desain."
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnPilihFile"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginBottom="12dp"
                            android:backgroundTint="#FFFFFF"
                            android:text="Pilih File"
                            android:textAllCaps="false"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="#EEEEEE"
                            app:strokeWidth="1dp"/>

                        <EditText
                            android:id="@+id/etCatatan"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="#FFFFFF"
                            android:gravity="top|start"
                            android:hint="Contoh: Tolong desain warna pastel..."
                            android:padding="12dp"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#F5F6F8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btnMinQty"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:backgroundTint="#FFFFFF"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="-"
                        android:textColor="#2D3142"
                        app:cornerRadius="4dp" />

                    <TextView
                        android:id="@+id/tvQty"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textAlignment="center"
                        android:textColor="#2D3142"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnPlusQty"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:backgroundTint="#FFFFFF"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textColor="#2D3142"
                        app:cornerRadius="4dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnTambahKeranjang"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:backgroundTint="#DD3827"
                    android:text="Tambah — Rp 16.000"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>