<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="2"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:id="@+id/tvAdminProdName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Produk" android:textStyle="bold" android:textColor="#2D3142" android:textSize="14sp"/>
        <TextView android:id="@+id/tvAdminProdCat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kategori" android:textColor="#64748B" android:textSize="10sp"/>
        <TextView android:id="@+id/tvAdminProdStock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stok: 10" android:textColor="#0D6EFD" android:textSize="10sp" android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAdminProdPrice"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="Rp 15000"
        android:textColor="#DD3827"
        android:textStyle="bold"
        android:textSize="12sp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnAdminEditProd"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:icon="@drawable/edit"
        app:iconTint="#000000"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        android:backgroundTint="#F9F9FB"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:layout_marginEnd="8dp"
        app:cornerRadius="8dp"/>

    <Button
        android:id="@+id/btnAdminHapusProd"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:icon="@drawable/trash"
        app:iconTint="#000000"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        android:backgroundTint="#F9F9FB"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:cornerRadius="8dp"/>

</LinearLayout>