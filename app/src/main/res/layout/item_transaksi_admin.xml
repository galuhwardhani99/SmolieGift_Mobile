<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesanan Baru"
                android:textColor="#F4511E"
                android:textStyle="bold"
                android:textSize="14sp"
                android:drawablePadding="8dp" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView android:id="@+id/tvAdminTransId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#INV-01" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="8dp"/>

        <TextView android:id="@+id/tvAdminTransNama" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Pemesan: Coco" android:textColor="#2D3142" android:textStyle="bold"/>
        <TextView android:id="@+id/tvAdminTransWa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WA: 08123456789" android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="4dp"/>
        <TextView android:id="@+id/tvAdminTransMetode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Metode: Tunai" android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvAdminTransTotal" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rp 50000" android:textColor="#DD3827" android:textStyle="bold" android:textSize="16sp" android:gravity="end" android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnHubungiWa"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Hubungi WA"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="16dp"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnSelesaiPesanan"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Selesai (Hapus)"
            android:backgroundTint="#64748B"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>