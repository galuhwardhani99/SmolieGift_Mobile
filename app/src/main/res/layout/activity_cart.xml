<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="← Kembali" android:textColor="#64748B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keranjang Saya" android:textStyle="bold" android:textColor="#2D3142"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llDaftarKeranjang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="2dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rincian Pembayaran" android:textStyle="bold" android:textSize="16sp" android:textColor="#2D3142" android:layout_marginBottom="16dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Total Bayar" android:textColor="#64748B"/>
                <TextView android:id="@+id/tvTotalBayarAkhir" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textStyle="bold" android:textSize="18sp" android:textColor="#DD3827"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NAMA PEMESAN" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B"/>

            <EditText
                android:id="@+id/etNamaPemesan"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@android:drawable/edit_text"
                android:hint="Tamu"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NOMOR WHATSAPP (AKTIF)" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B"/>

            <EditText
                android:id="@+id/etNoWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@android:drawable/edit_text"
                android:hint="08xxxxxxxxx"
                android:inputType="phone"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="METODE PEMBAYARAN" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                <Button android:layout_width="0dp" android:layout_weight="1" android:layout_height="45dp" android:text="Tunai" android:backgroundTint="#0D6EFD" android:textColor="#FFFFFF" android:layout_marginEnd="4dp"/>
                <Button android:layout_width="0dp" android:layout_weight="1" android:layout_height="45dp" android:text="QRIS" android:backgroundTint="#FFFFFF" android:textColor="#2D3142" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnKonfirmasi"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Konfirmasi Pesanan →"
                android:backgroundTint="#DC3545"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>