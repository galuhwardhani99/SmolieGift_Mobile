<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPembeli"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:title="Smolie Gift"
        app:titleTextColor="#DD3827"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/contentFramePembeli"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarPembeli"
        app:layout_constraintBottom_toTopOf="@id/bottomNavPembeli">

        <ScrollView
            android:id="@+id/layoutHomePembeli"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="32dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FF7A68"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#DD3827"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cari Souvenir Unik &amp; Cantik?"
                            android:textAlignment="center"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Temukan beragam pilihan custom souvenir di sini!"
                            android:textAlignment="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Fitur AutoCompleteTextView Pencarian -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cari Produk"
                        android:textColor="#2D3142"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <AutoCompleteTextView
                        android:id="@+id/acSearchProduk"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_spinner"
                        android:hint="Ketik nama produk..."
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:textSize="14sp"
                        android:completionThreshold="1"
                        android:singleLine="true"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnLihatKeranjang"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Lihat Keranjang Belanja"
                    app:icon="@drawable/shopping_cart"
                    app:iconGravity="textStart"
                    android:backgroundTint="#FDE8E5"
                    android:textColor="#DD3827"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Katalog Produk"
                    android:textColor="#2D3142"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp"/>

                <GridLayout
                    android:id="@+id/glDaftarProdukPembeli"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false" />
            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/fragmentContainerPembeli"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/layoutProfilePembeli"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_person"
                    app:tint="#DD3827"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Pembeli"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2D3142"/>

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textSize="16sp"
                    android:textColor="#64748B"
                    android:layout_marginBottom="32dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:backgroundTint="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informasi Akun"
                            android:textStyle="bold"
                            android:textColor="#2D3142"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvProfileUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username: -"
                            android:textColor="#64748B"/>

                        <TextView
                            android:id="@+id/tvProfilePhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telepon: -"
                            android:textColor="#64748B"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:id="@+id/tvProfileAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alamat: -"
                            android:textColor="#64748B"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:id="@+id/tvProfileGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gender: -"
                            android:textColor="#64748B"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavPembeli"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/pembeli_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>