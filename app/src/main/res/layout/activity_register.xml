<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buat Akun Baru"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2D3142"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"/>

        <EditText android:id="@+id/etRegNama" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Nama Lengkap" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp" android:layout_marginBottom="16dp"/>

        <EditText android:id="@+id/etRegEmail" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Email" android:inputType="textEmailAddress" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp" android:layout_marginBottom="16dp"/>

        <EditText android:id="@+id/etRegUsername" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Username" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp" android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Spinner android:id="@+id/spRegGender" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:layout_marginEnd="8dp" android:background="#F5F6F8" android:paddingStart="12dp"/>

            <EditText android:id="@+id/etRegPhone" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:hint="No HP" android:inputType="phone" android:layout_marginStart="8dp" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp"/>
        </LinearLayout>

        <EditText android:id="@+id/etRegAddress" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Alamat Lengkap" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp" android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="32dp">
            <EditText android:id="@+id/etRegPassword" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:hint="Password" android:inputType="textPassword" android:layout_marginEnd="8dp" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp"/>

            <EditText android:id="@+id/etRegConfirmPass" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:hint="Konfirmasi" android:inputType="textPassword" android:layout_marginStart="8dp" android:background="#F5F6F8" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#2D3142" android:textSize="14sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Daftar Sekarang"
            android:backgroundTint="#DD3827"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvGoToLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sudah memiliki akun? Masuk di sini"
            android:gravity="center"
            android:textColor="#DD3827"
            android:textStyle="bold"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>