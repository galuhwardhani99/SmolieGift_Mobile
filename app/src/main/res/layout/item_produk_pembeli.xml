<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivPembeliProdImage"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:background="#EEEEEE"
            android:scaleType="centerCrop"
            android:src="@drawable/snackbox" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvPembeliProdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Produk"
                android:textStyle="bold"
                android:textColor="#2D3142"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvPembeliProdCat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvPembeliProdPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#DD3827"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPesanKatalog"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Pesan"
                android:backgroundTint="#DD3827"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>